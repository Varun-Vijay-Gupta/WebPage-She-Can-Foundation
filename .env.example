# Backend environment variables (copy this file to backend/.env)

NODE_ENV=development
PORT=5000

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=she_can_foundation
DB_CONNECTION_LIMIT=10

# CORS (comma-separated origins for production)
CORS_ORIGIN=http://localhost:5500,http://127.0.0.1:5500

# Prevent rapid duplicate form submissions (seconds)
SUBMISSION_COOLDOWN_SECONDS=10

# Admin dashboard API key (used in frontend/admin login)
ADMIN_API_KEY=change_this_to_a_strong_secret_key

# Email notifications (Gmail example - use App Password, not regular password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
NOTIFY_EMAIL=
